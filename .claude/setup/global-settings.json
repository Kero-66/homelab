{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/check-ai-standards-version.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/log-bash-commands.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/token-optimizer-collect.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/remind-troubleshooting-docs.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/mempalace-stop.sh\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/mempalace-precompact.sh\"",
            "timeout": 90
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "caveman@caveman": true,
    "mempalace@mempalace": true,
    "token-optimizer@alexgreensh-token-optimizer": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "git",
        "url": "https://github.com/JuliusBrussee/caveman.git"
      }
    },
    "mempalace": {
      "source": {
        "source": "git",
        "url": "https://github.com/milla-jovovich/mempalace.git"
      }
    },
    "alexgreensh-token-optimizer": {
      "source": {
        "source": "github",
        "repo": "alexgreensh/token-optimizer"
      }
    }
  },
  "effortLevel": "medium",
  "theme": "light",
  "verbose": true,
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/hooks/token-optimizer-statusline.sh\""
  },
  "cleanupPeriodDays": 99999
}
